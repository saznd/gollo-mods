.card{
  width: 400px;
  height: 230px;
  border:1px solid #aaa;
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:center;
  background: rgba(0, 0, 0, 0.863);
  transition: all 1s ease;
  gap: 18px;

  position: relative;
  overflow: hidden; /* clave para el flash */
}

.card:hover{
  transform: translateY(-8px);
  box-shadow:
    0 0 15px rgba(255,255,255,0.2);

}

/* ============================= */
/* ✨ FLASH SUAVE TIPO NEBLINA (UNIFICADO PARA TODO) ✨ */
/* ============================= */

.card::before,
.aporte-card::before {
  content: "";
  position: absolute;
  top: 0;
  left: -150%;
  width: 120%;
  height: 100%;

  background: linear-gradient(
    120deg,
    rgba(255,255,255,0) 0%,
    rgba(200,80,255,0.4) 45%,
    rgba(255,255,255,0) 100%
  );

  filter: blur(18px);        /* ← hace que sea NEBLINA y no mancha */
  transform: skew(-15deg);
  opacity: 0;
  transition: opacity 0.4s ease;
}

/* Se activa al pasar el mouse en TODOS los apartados */
.card:hover::before,
.aporte-card:hover::before {
  opacity: 1;
  animation: flash 1.4s ease;
}

/* Animación de barrido */
@keyframes flash {
  0% { left: -150%; }
  100% { left: 150%; }
}


/* Animación del flash */
@keyframes flash {
  0% { left: -150%; }
  100% { left: 150%; }
}


