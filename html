.video-thumb{
  position: relative;
  margin: 12px 0;
  border: 1px solid #aaa;
}

.video-thumb img{
  width: 100%;
  display: block;
}

.play{
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: red;
  color: white;
  width: 50px;
  height: 50px;
  border-radius: 50%;
  display:flex;
  align-items:center;
  justify-content:center;
  font-size: 22px;
}

.btn-descarga{
  display:block;
  text-align:center;
  background: linear-gradient(90deg, #a020f0, #2a003f);
  color:white;
  text-decoration:none;
  padding:14px;
  font-family: "MiBoton", "Orbitronht", sans-serif;
  font-size: 18px;           /* ← AUMENTA TAMAÑO DE LETRA */
  letter-spacing: 2px;       /* separación inicial */
  border: 1px solid #aaa;
  transition: all 0.35s ease;
}

/* brillo al pasar el mouse */
.btn-descarga:hover{
  box-shadow: 0 0 15px rgba(255,255,255,0.2);
  transform: translateY(-2px);
}
.btn-descarga:hover{
  box-shadow: 0 0 15px rgba(255,255,255,0.2);
  transform: translateY(-4px) scale(1.03); /* SALTO SUAVE */
  letter-spacing: 5px;  /* LAS LETRAS SE SEPARAN */
  animation: latido 2.0s infinite; /* PALPITAR */
}

/* ANIMACIÓN DE PALPITAR */
@keyframes latido {
  0% { transform: translateY(-4px) scale(1.03); }
  50% { transform: translateY(-6px) scale(1.06); }
  100% { transform: translateY(-4px) scale(1.03); }
}



