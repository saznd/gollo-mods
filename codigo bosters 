  display: flex;
  justify-content: center;
  padding: 0;
}

.menu{
  background: rgba(0, 0, 0, 0.85);
  padding: 12px 20px;
  border-radius: 6px;
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 12px;
  flex-wrap: nowrap;
  width: 100%;
  max-width: 1200px;
  margin-left: auto;
  margin-right: auto;
}

.menu button{
  background: linear-gradient(135deg, #cc0000, #8b0000);
  color: white;
  border: none;
  padding: 10px 22px;
  cursor: pointer;
  font-weight: bold;
  text-transform: uppercase;
  transition: all 0.2s ease;
  font-family: "Orbitronht", sans-serif;
  letter-spacing: 1px;
  border-radius: 4px;
  position: relative;
  overflow: hidden;
  box-shadow: 0 2px 5px rgba(0,0,0,0.3);
}

.menu button span{
  display: inline-block;
  position: relative;
  z-index: 2;
}

/* EFECTO DE DISPARO / DESTELLO ROJO-BLANCO */
.menu button::before {
  content: "";
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.8), rgba(255,100,100,0.9), transparent);
  transition: left 0.35s cubic-bezier(0.2, 1.2, 0.8, 1);
  z-index: 1;
  pointer-events: none;
}

.menu button:hover::before {
  left: 100%;
}

.menu button:hover {
  background: linear-gradient(135deg, #ff3333, #cc0000);
  transform: scale(1.02);
  box-shadow: 0 0 8px rgba(0,0,0,0.5);
}

.menu button.activo {
  background: linear-gradient(135deg, #ff4444, #990000);
  box-shadow: 0 0 10px rgba(0,0,0,0.6);
  transform: scale(1.02);
  border: 1px solid rgba(255,255,255,0.3);
}

